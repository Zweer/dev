{
  "name": "@zweer/dev",
  "version": "2.0.0",
  "description": "Shared configurations, golden configs & Kiro AI templates for software projects",
  "keywords": ["cli", "development", "kiro", "configs", "tooling"],
  "homepage": "https://github.com/Zweer/dev#readme",
  "bugs": { "url": "https://github.com/Zweer/dev/issues" },
  "license": "MIT",
  "author": "Zweer <n.olivieriachille@gmail.com>",
  "files": ["dist/**/*", "configs/**/*", "kiro/**/*", "workflows/**/*"],
  "bin": "./dist/cli/index.js",
  "repository": { "type": "git", "url": "git+https://github.com/Zweer/dev.git" },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "lint": "concurrently npm:lint:* --prefixColors auto",
    "lint:engines": "ls-engines",
    "lint:format": "biome check --write",
    "lint:lockfile": "lockfile-lint",
    "lint:package": "npmPkgJsonLint .",
    "lint:sort_package": "sort-package-json \"package.json\"",
    "lint:typecheck": "tsc --noEmit",
    "prepare": "lefthook install",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^12.1.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^4.0.8",
    "concurrently": "^9.2.1",
    "lefthook": "^1.12.0",
    "lockfile-lint": "^4.14.1",
    "ls-engines": "^0.10.0",
    "npm-package-json-lint": "^9.0.0",
    "rimraf": "^6.1.0",
    "sort-package-json": "^3.6.1",
    "tsdown": "^0.12.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "engines": { "node": ">= 22" },
  "publishConfig": { "access": "public", "provenance": true }
}
